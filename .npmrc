auto-install-peers=false
# Zero browser download (plan 026 decision 2): never run Playwright's Chromium
# postinstall. E2E drives an already-installed system browser via the `channel`
# option, so the bundled-browser download is pure waste. Belt & suspenders with
# the CI install-step env PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 and pnpm not listing
# playwright in pnpm-workspace.yaml `allowBuilds` (its build script stays blocked).
playwright_skip_browser_download=1
