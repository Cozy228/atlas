{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "promise"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "react-hooks/exhaustive-deps": "warn"
  },
  "env": {
    "builtin": true,
    "browser": true
  },
  "settings": {
    "react": {
      "version": "19.2"
    }
  },
  "ignorePatterns": ["dist", ".output", "node_modules", "**/routeTree.gen.ts"]
}
