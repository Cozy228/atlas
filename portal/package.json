{
  "name": "@atlas/portal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "generate:routes": "node ./scripts/generate-routes.mjs",
    "lint": "tsc --noEmit --pretty false",
    "typecheck": "pnpm run generate:routes && tsc --noEmit --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "@atlas/context-layer": "workspace:*",
    "@atlas/schema": "workspace:*",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@fontsource/ibm-plex-sans": "5.2.8",
    "@tabler/icons-react": "3.42.0",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-start": "1.167.64",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/router-generator": "1.166.41",
    "@tanstack/router-plugin": "1.167.34",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  }
}
