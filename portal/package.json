{
  "name": "@atlas/portal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "generate:routes": "node ./scripts/generate-routes.mjs",
    "lint": "oxlint && tsc --noEmit --pretty false",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "measure:availability-render": "vitest run scripts/measure-availability-render-cost.debug.test.tsx --reporter verbose",
    "typecheck": "pnpm run generate:routes && tsc --noEmit --pretty false",
    "test": "vitest run --exclude scripts/*.debug.test.tsx"
  },
  "dependencies": {
