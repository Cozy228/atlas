    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "fuse.js": "^7.3.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.11",
    "react": "19.2.6",
