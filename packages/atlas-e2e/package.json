    "typecheck": "tsc --noEmit --pretty false",
    "lint": "tsc --noEmit --pretty false"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "26.0.0",
    "typescript": "6.0.3"
  }
}
