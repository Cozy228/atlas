{
  "name": "azure-react-icons",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./icons/*": {
      "types": "./src/icons/*.tsx",
      "import": "./src/icons/*.tsx"
    }
  },
  "scripts": {
    "generate": "node ./scripts/generate-icons.mjs",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "*"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "react": "^19.2.7",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  }
}
